    {
      "name": "🌴 Leave Management",
      "item": [
        {
          "name": "Get Leave Dashboard (Image 4)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Dashboard loaded (200)', () => pm.response.to.have.status(200));",
                "const d = pm.response.json().data;",
                "pm.test('Has balanceCards', () => pm.expect(d.balanceCards).to.be.an('array'));",
                "pm.test('Has upcomingLeaves', () => pm.expect(d.upcomingLeaves).to.be.an('array'));",
                "pm.test('Has pendingRequests', () => pm.expect(d.pendingRequests).to.be.an('array'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/leave/me/dashboard"
          },
          "_thesis_note": "Powers the entire Leave Dashboard (Image 4). Returns: 4 balance cards (Annual 17/25, Sick 12/15, Emergency 4/5, Sabbatical 180/180), upcoming leaves section, and pending requests with status badges."
        },
        {
          "name": "Submit Leave Request (Annual)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Leave submitted (201)', () => pm.response.to.have.status(201));",
                "const d = pm.response.json().data;",
                "pm.collectionVariables.set('leaveRequestId', d.LeaveRequestID);",
                "pm.test('Status is PendingManager', () => pm.expect(d.Status).to.eql('PendingManager'));"
              ]
            }
          }],
