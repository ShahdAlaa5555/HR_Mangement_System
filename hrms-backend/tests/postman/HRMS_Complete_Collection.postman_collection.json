          "_thesis_note": "Powers the Employee Self-Service profile card (Image 1). Returns personal info, job info, department, position, supervisor, and work location."
        },
        {
          "name": "List All Employees (HR View)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/employees?page=1&limit=20&status=Active&departmentId=1",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "Active" },
                { "key": "departmentId", "value": "1" },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "List Employees — with Search",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees?search=Johnson&status=Active"
          },
          "_thesis_note": "Searches across EmployeeCode, FullName, and Email simultaneously."
        },
