          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/employees",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"EmployeeCode\": \"EMP099\",\n  \"FirstName\": \"Test\",\n  \"LastName\": \"User\",\n  \"DateOfBirth\": \"1990-01-01\",\n  \"Gender\": \"Male\",\n  \"Nationality\": \"Egyptian\",\n  \"MaritalStatus\": \"Single\",\n  \"Email\": \"sarah.johnson@university.edu\",\n  \"DepartmentID\": 1,\n  \"PositionID\": 1,\n  \"EmploymentType\": \"Full-Time\",\n  \"StartDate\": \"2025-01-01\",\n  \"WorkLocationID\": 1\n}"
            }
          },
          "_expected": "409 DUPLICATE_ENTRY — email already registered"
        },
        {
          "name": "Update Employee (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/employees/{{employeeId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"Phone\": \"+20-10-9999-9999\",\n  \"Address\": \"456 New Address, Cairo, Egypt\"\n}" }
          }
