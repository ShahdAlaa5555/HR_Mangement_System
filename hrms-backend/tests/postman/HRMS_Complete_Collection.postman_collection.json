              "raw": "{\n  \"EmployeeCode\": \"EMP010\",\n  \"FirstName\": \"Ahmed\",\n  \"LastName\": \"Hassan\",\n  \"DateOfBirth\": \"1990-03-15\",\n  \"Gender\": \"Male\",\n  \"Nationality\": \"Egyptian\",\n  \"MaritalStatus\": \"Married\",\n  \"Email\": \"ahmed.hassan@university.edu\",\n  \"Phone\": \"+20-10-1234-5678\",\n  \"Address\": \"123 Tahrir Square, Cairo\",\n  \"DepartmentID\": 1,\n  \"PositionID\": 2,\n  \"EmploymentType\": \"Full-Time\",\n  \"StartDate\": \"2025-01-01\",\n  \"WorkLocationID\": 1,\n  \"SupervisorID\": 1,\n  \"HasDisability\": false\n}"
            }
          }
