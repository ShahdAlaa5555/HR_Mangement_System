{
  "info": {
    "name": "University HRMS — Complete API Collection",
    "_postman_id": "hrms-thesis-2025",
    "description": "Complete Postman collection for the University HR Management System backend.\n\nSETUP:\n1. Set base_url = http://localhost:3000\n2. Run 'POST /auth/login' first to auto-set the {{token}} variable\n3. All other requests use {{token}} automatically\n\nTEST SCENARIOS included for each endpoint:\n- Success case (200/201)\n- Validation failure (422)\n- Auth failure (401)\n- Business rule failure (400)\n- Not found (404)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "employeeId", "value": "1", "type": "string" },
    { "key": "leaveRequestId", "value": "1", "type": "string" },
    { "key": "attendanceId", "value": "1", "type": "string" },
    { "key": "payrollRunId", "value": "1", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login (Employee)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const json = pm.response.json();",
                "  pm.collectionVariables.set('token', json.data.accessToken);",
                "  pm.collectionVariables.set('employeeId', json.data.employee.id);",
                "  console.log('Token set. Role:', json.data.employee.role);",
                "}",
                "pm.test('Login successful', () => pm.response.to.have.status(200));",
                "pm.test('Token received', () => pm.expect(pm.response.json().data.accessToken).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah.johnson@university.edu\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "_thesis_note": "Standard login. On success, the test script auto-saves the token to the {{token}} variable for all subsequent requests."
        },
        {
          "name": "Login (HR Role)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hr.manager@university.edu\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login — FAIL: Invalid Password",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Returns 401 for bad credentials', () => pm.response.to.have.status(401));",
                "pm.test('Error code is INVALID_CREDENTIALS', () => {",
                "  pm.expect(pm.response.json().error.code).to.eql('INVALID_CREDENTIALS');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"sarah.johnson@university.edu\",\n  \"password\": \"wrongpassword\"\n}" }
          }
        },
        {
          "name": "Login — FAIL: Missing Field",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"sarah.johnson@university.edu\"\n}" }
          },
          "_expected": "422 VALIDATION_ERROR — password is required"
        },
        {
          "name": "Get My Identity (auth/me)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },

    {
      "name": "👤 Employee Profile",
      "item": [
        {
          "name": "Get My Profile (Image 1)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has EmployeeCode', () => pm.expect(pm.response.json().data.EmployeeCode).to.exist);",
                "pm.test('Has Department', () => pm.expect(pm.response.json().data.Department).to.exist);"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/employees/me"
