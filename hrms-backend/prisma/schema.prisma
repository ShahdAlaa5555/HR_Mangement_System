generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Department {
  DepartmentID   Int        @id(map: "PK__Departme__B2079BCDD16BD357") @default(autoincrement())
  DepartmentCode String     @unique(map: "UQ__Departme__6EA8896DBB16E819") @db.NVarChar(20)
  DepartmentName String     @db.NVarChar(100)
  ManagerID      Int?
  IsActive       Boolean    @default(true, map: "DF__Departmen__IsAct__38996AB5")
  CreatedAt      DateTime   @default(dbgenerated("getutcdate()"), map: "DF__Departmen__Creat__398D8EEE")
  UpdatedAt      DateTime   @default(dbgenerated("getutcdate()"), map: "DF__Departmen__Updat__3A81B327")
  Manager        Employee?  @relation("DepartmentManager", fields: [ManagerID], references: [EmployeeID], onDelete: NoAction, onUpdate: NoAction, map: "FK_Department_Manager")
  Employees      Employee[] @relation("EmployeeDepartment")
}

model Position {
  PositionID    Int        @id(map: "PK__Position__60BB9A59D2E3308A") @default(autoincrement())
  PositionCode  String     @unique(map: "UQ__Position__83745B0227E10275") @db.NVarChar(20)
