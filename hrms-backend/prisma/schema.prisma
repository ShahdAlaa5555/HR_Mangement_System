  UpdatedAt     DateTime   @default(dbgenerated("getutcdate()"), map: "DF__Position__Update__403A8C7D")
  Employees     Employee[]
  PayGrade      PayGrade?  @relation(fields: [PayGradeID], references: [PayGradeID], onDelete: NoAction, onUpdate: NoAction, map: "FK_Position_PayGrade")
}

model WorkLocation {
